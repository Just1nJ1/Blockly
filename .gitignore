# =============================================================================
# Blockly Desktop App .gitignore
# =============================================================================

# --- Embedded Python runtimes (downloaded via scripts/download-python.js) ---
# These are large (~216 MB), platform-specific, binary build artifacts.
# They should be downloaded on demand, never committed to git.
python/

# --- Node / Electron ---
node_modules/
dist/

# --- Python bytecode (Flask server) ---
__pycache__/
*.py[codz]

# --- OS / Editor ---
.DS_Store
.idea/
.vscode/
*.swp
*~
