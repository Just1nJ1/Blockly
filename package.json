{
  "name": "blockly-desktop-app",
  "version": "1.0.0",
  "description": "WLKATA StudioX - Visual programming for robotic arms",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "setup": "node scripts/download-python.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:all": "electron-builder --win --mac --linux --publish never",
    "postinstall": "electron-builder install-app-deps && npm run setup"
  },
  "keywords": [
    "blockly",
    "electron",
    "python",
    "visual-programming"
  ],
  "author": {
    "name": "Haochen Ji",
    "email": "haochen.justin.ji@gmail.com"
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "blockly": "^12.4.1"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.example.blocklyapp",
    "productName": "WLKATA StudioX",
    "icon": "resources/icons/icon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "css/**/*",
      "js/**/*",
      "node_modules/**/*",
      "resources/6dof/**/*",
      "resources/icons/**/*",
      "index.html",
      "main.js"
    ],
    "extraResources": [
      {
        "from": "extensions",
        "to": "extensions",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "server.py",
        "to": "server.py"
      },
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/esptool.cfg",
        "to": "esptool.cfg"
      },
      {
        "from": "resources/firmware",
        "to": "firmware",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "WLKATA-StudioX-Mac-${arch}.${ext}",
      "extraResources": [
        {
          "from": "resources/python",
          "to": "python",
          "filter": ["**/*"]
        },
        {
          "from": "resources/avrdude/avrdude_macOS_64bit",
          "to": "avrdude/avrdude_macOS_64bit",
          "filter": ["**/*"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "WLKATA-StudioX-Win-${arch}.${ext}",
      "extraResources": [
        {
          "from": "resources/python",
          "to": "python",
          "filter": ["**/*"]
        },
        {
          "from": "resources/avrdude/avrdude-v8.1-windows-x64",
          "to": "avrdude/avrdude-v8.1-windows-x64",
          "filter": ["**/*"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "allowElevation": true,
      "runAfterFinish": true,
      "include": "build/installer.nsh",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "shortcutName": "WLKATA StudioX"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "deb",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "Education",
      "artifactName": "WLKATA-StudioX-Linux-${arch}.${ext}",
      "extraResources": [
        {
          "from": "resources/python",
          "to": "python",
          "filter": ["**/*"]
        },
        {
          "from": "resources/avrdude/avrdude_Linux_64bit",
          "to": "avrdude/avrdude_Linux_64bit",
          "filter": ["**/*"]
        },
        {
          "from": "resources/avrdude/avrdude_Linux_ARM64",
          "to": "avrdude/avrdude_Linux_ARM64",
          "filter": ["**/*"]
        }
      ]
    }
  }
}
