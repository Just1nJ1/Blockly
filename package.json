{
  "name": "blockly-desktop-app",
  "version": "1.0.0",
  "description": "A Blockly desktop application with Python backend execution",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "setup": "node scripts/download-python.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:all": "electron-builder --win --mac --publish never",
    "postinstall": "electron-builder install-app-deps && npm run setup"
  },
  "keywords": [
    "blockly",
    "electron",
    "python",
    "visual-programming"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "blockly": "^12.4.1"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.example.blocklyapp",
    "productName": "WLKATA Blockly",
    "icon": "resources/icons/icon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "js/**/*",
      "node_modules/**/*",
      "server/**/*",
      "resources/6dof/**/*",
      "resources/icons/**/*",
      "index.html",
      "main.js",
      "server.py"
    ],
    "extraResources": [
      {
        "from": "server.py",
        "to": "server.py"
      },
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "WLKATA-Blockly-Mac-${arch}.${ext}",
      "extraResources": [
        {
          "from": "resources/python",
          "to": "python",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "WLKATA-Blockly-Win-${arch}.${ext}",
      "extraResources": [
        {
          "from": "resources/python",
          "to": "python",
          "filter": [
            "**/*"
          ]
        }
      ]
    }
  }
}
